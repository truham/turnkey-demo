{
  "info": {
    "name": "Turnkey API",
    "_postman_id": "turnkey-api-collection",
    "description": "Turnkey REST API collection with auto X-Stamp generation.\n\nSetup:\n1. Set collection variables: API_PUBLIC_KEY, API_PRIVATE_KEY_HEX, ORGANIZATION_ID\n2. The pre-request script auto-generates X-Stamp for every request\n3. BASE_URL defaults to https://api.turnkey.com\n\nStamp algorithm:\n- ECDSA-P256 sign the raw JSON body bytes\n- DER-encode the signature, hex-encode it\n- Base64URL encode JSON: {publicKey, signature, scheme}\n- Set as X-Stamp header",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "BASE_URL",
      "value": "https://api.turnkey.com"
    },
    {
      "key": "API_PUBLIC_KEY",
      "value": "03e369a8b6b822f49773aa06269062f3cd4b51218b2a13063f5e3fcb9ea326eaa8"
    },
    {
      "key": "ORGANIZATION_ID",
      "value": "e067c158-42ef-461a-afe3-b0f283a62eb2"
    },
    {
      "key": "JWK_X",
      "value": "42motrgi9JdzqgYmkGLzzUtRIYsqEwY_Xj_LnqMm6qg",
      "description": "P-256 public key x coordinate (base64url). Derived from API_PUBLIC_KEY."
    },
    {
      "key": "JWK_Y",
      "value": "nhgSSFp235yneoa6wYZuSvXB0F51_CkicyoSizNlnpk",
      "description": "P-256 public key y coordinate (base64url). Derived from API_PUBLIC_KEY."
    },
    {
      "key": "JWK_D",
      "value": "WBZDS2inVoEzvLxuwQpycqV1bDt6DRJ18LkNo4jdV4A",
      "type": "secret",
      "description": "P-256 private key scalar (base64url). Keep secret — used to sign requests."
    },
    {
      "key": "X_STAMP",
      "value": "",
      "description": "Auto-populated by the collection pre-request script before each request. Do not set manually."
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Auto-generate X-Stamp header for every Turnkey request.",
          "// Uses Postman's built-in done() callback to block the request until",
          "// the async crypto.subtle signing completes. Without calling done(),",
          "// Postman fires the request immediately with a stale/missing X_STAMP.",
          "//",
          "// Stamp algorithm (matches @turnkey/api-key-stamper exactly):",
          "//   1. Import private key as JWK (SubtleCrypto only accepts JWK for P-256 signing)",
          "//   2. ECDSA-P256 + SHA-256 sign the raw request body bytes",
          "//   3. Convert IEEE P1363 output (r||s) → DER-encoded ASN.1",
          "//   4. Build { publicKey, scheme, signature } — field order matters",
          "//   5. base64url-encode → X-Stamp header",
          "",
          "// done is Postman's async signal — guard for versions that don't inject it",
          "if (typeof done === 'undefined') { var done = function() {}; }",
          "",
          "function generateStamp(done) {",
          "  const publicKey = pm.collectionVariables.get('API_PUBLIC_KEY');",
          "  const jwkX      = pm.collectionVariables.get('JWK_X');",
          "  const jwkY      = pm.collectionVariables.get('JWK_Y');",
          "  const jwkD      = pm.collectionVariables.get('JWK_D');",
          "  const rawBody   = pm.variables.replaceIn(pm.request.body ? pm.request.body.toString() : '{}');",
          "  console.log('Signing body:', rawBody.substring(0, 80));",
          "",
          "  function convertIeeeToDer(ieee) {",
          "    const ieeeArr = new Uint8Array(ieee);",
          "    function toUnsignedBigNum(bytes) {",
          "      let start = 0;",
          "      while (start < bytes.length && bytes[start] === 0) start++;",
          "      if (start === bytes.length) start = bytes.length - 1;",
          "      const extraZero = (bytes[start] & 128) === 128 ? 1 : 0;",
          "      const res = new Uint8Array(bytes.length - start + extraZero);",
          "      res.set(bytes.subarray(start), extraZero);",
          "      return res;",
          "    }",
          "    const r = toUnsignedBigNum(ieeeArr.subarray(0, ieeeArr.length / 2));",
          "    const s = toUnsignedBigNum(ieeeArr.subarray(ieeeArr.length / 2));",
          "    const bodyLen = 1 + 1 + r.length + 1 + 1 + s.length;",
          "    let der; let offset = 0;",
          "    if (bodyLen >= 128) {",
          "      der = new Uint8Array(bodyLen + 3);",
          "      der[offset++] = 48; der[offset++] = 129; der[offset++] = bodyLen;",
          "    } else {",
          "      der = new Uint8Array(bodyLen + 2);",
          "      der[offset++] = 48; der[offset++] = bodyLen;",
          "    }",
          "    der[offset++] = 2; der[offset++] = r.length; der.set(r, offset); offset += r.length;",
          "    der[offset++] = 2; der[offset++] = s.length; der.set(s, offset);",
          "    return der;",
          "  }",
          "",
          "  crypto.subtle.importKey(",
          "    'jwk',",
          "    { kty: 'EC', crv: 'P-256', x: jwkX, y: jwkY, d: jwkD },",
          "    { name: 'ECDSA', namedCurve: 'P-256' },",
          "    false,",
          "    ['sign']",
          "  ).then(function(cryptoKey) {",
          "    return crypto.subtle.sign(",
          "      { name: 'ECDSA', hash: 'SHA-256' },",
          "      cryptoKey,",
          "      new TextEncoder().encode(rawBody)",
          "    );",
          "  }).then(function(sigBuffer) {",
          "    const derSig = convertIeeeToDer(sigBuffer);",
          "    const sigHex = Array.from(derSig).map(function(b) { return b.toString(16).padStart(2, '0'); }).join('');",
          "    const stampJson = JSON.stringify({",
          "      publicKey: publicKey,",
          "      scheme: 'SIGNATURE_SCHEME_TK_API_P256',",
          "      signature: sigHex",
          "    });",
          "    const stamp = btoa(stampJson).replace(/\\+/g, '-').replace(/\\//g, '_').replace(/=/g, '');",
          "    pm.environment.set('X_STAMP', stamp);",
          "    console.log('✓ X-Stamp set, sending request');",
          "    done();",
          "  }).catch(function(e) {",
          "    console.error('✗ Stamp failed:', e.message);",
          "    done(e);",
          "  });",
          "}",
          "",
          "generateStamp(done);"
        ]
      }
    }
  ],
